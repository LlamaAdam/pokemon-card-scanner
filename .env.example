# pokemontcg.io API key (optional; raises rate limit). Leave blank for anonymous use.
POKEMONTCG_API_KEY=

# Upstash Redis (used as the PSA 10 price cache).
# Get free credentials at https://console.upstash.com — create a Redis database
# (Regional or Global) and copy the REST URL + token from its dashboard.
# Leave blank for local dev: the app will fall back to an in-memory cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV env names are still honored as a fallback (they point at
# the same underlying Upstash service) — only needed if your project already
# has a Vercel KV integration attached.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
